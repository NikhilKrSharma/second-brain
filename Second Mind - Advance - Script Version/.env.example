# Optional: OpenAI-compatible chat completions (omit to use manual copy/paste workflow)
KNS_LLM_BASE_URL=https://api.openai.com/v1
KNS_LLM_API_KEY=
KNS_LLM_MODEL=gpt-4o-mini

# Deduplication: skip (default) or append to existing similar title
KNS_DEDUP_MODE=skip
KNS_DEDUP_THRESHOLD=0.86

# Require complete YAML frontmatter from the model (stricter failures)
# KNS_STRICT_FRONTMATTER=true

# Atomicity / links / pre-dedup (defaults match scripts/config.py)
# KNS_MAX_NOTE_WORDS=2000
# KNS_ENABLE_PLACEHOLDER_LINKS=true
# KNS_PRE_DEDUP_ENABLED=true

# Placeholder stubs: min occurrences (see scripts/wikilinks.py for long-target exception)
# KNS_PLACEHOLDER_MIN_OCCURRENCE=2

# Auto-split oversized notes via second LLM call (prompts/split.md)
# KNS_AUTO_SPLIT_OVERSIZED=true

# Extra ingest.log lines after successful writes
# KNS_LEARNING_LOOP=false

# Optional overrides
# KNS_REPO_ROOT=/absolute/path/to/knowledge-system
